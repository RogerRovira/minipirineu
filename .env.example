# Copy to .env (gitignored) and fill in for local live runs: fixture
# recording, `pytest -m live`, manual `python -m minipirineu.ingest_meteocat`.
# CI never reads .env — workflows get keys from GitHub Actions secrets.

# Meteocat API key (Predicció plan, 100 calls/month — mind the quota)
METEOCAT_API_KEY=

# Optional: local datastore root (defaults to ./datastore, gitignored)
# MINIPIRINEU_DATA_DIR=
